---
import '../../../styles/global.css';
import SiteHeader from '../../../components/SiteHeader.astro';
import Footer from '../../../components/Footer.astro';
import RuntimeArch from '../../../components/diagrams/RuntimeArch.astro';

const locale = 'ja';
---

<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <title>ai-lib-ts | AI-Protocol TypeScript/Node.js ランタイム</title>
    <meta
      name="description"
      content="AI-Protocol 向け TypeScript/Node.js ランタイム。HttpTransport + マニフェスト解析、/core と /contact。"
    />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <SiteHeader locale={locale} />

    <main>
      <!-- Hero -->
      <section class="relative pt-16 pb-20 overflow-hidden">
        <div class="absolute inset-0 -z-10">
          <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl"></div>
          <div class="absolute bottom-0 left-1/3 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl">
          </div>
        </div>
        <div class="container">
          <div class="max-w-4xl">
            <div
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20 mb-6"
            >
              v1.0.0 &middot; npm
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6 leading-[1.05]">
              <span class="gradient-text">TypeScript ランタイム</span>
              <br />
              <span class="text-[var(--text)]">AI-Protocol 向け。</span>
            </h1>
            <p class="text-lg md:text-xl text-[var(--text-dim)] max-w-2xl mb-8 leading-relaxed">
              プロトコル駆動の TypeScript/Node.js ランタイム（v1.0.0）。HttpTransport + マニフェスト解析。
              /core と /contact、V2 エラーコード 13 種。
            </p>
            <div class="flex flex-wrap gap-4 mb-8">
              <a
                href="/ja/ts/quickstart/"
                class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-all hover:no-underline"
                >クイックスタート</a
              >
              <a
                href="https://github.com/ailib-official/ai-lib-ts"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] text-[var(--text)] font-semibold rounded-lg hover:bg-[var(--bg-alt)] transition-all hover:no-underline"
                >GitHub</a
              >
              <a
                href="https://www.npmjs.com/package/@ailib-official/ai-lib-ts"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] text-[var(--text)] font-semibold rounded-lg hover:bg-[var(--bg-alt)] transition-all hover:no-underline"
                >npm</a
              >
            </div>

            <!-- Quick install -->
            <div class="bg-[#0d1117] border border-[var(--border)] rounded-lg p-4 max-w-lg">
              <div class="text-xs text-[var(--text-muted)] mb-2 font-mono">npm install</div>
              <code class="text-sm text-blue-300 font-mono">npm install @ailib-official/ai-lib-ts</code>
            </div>
          </div>
        </div>
      </section>

      <!-- Key Features -->
      <section class="section-alt">
        <div class="container">
          <h2 class="text-3xl font-bold text-[var(--text)] mb-10 text-center">主な機能</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">V2 マニフェスト解析</h3>
              <p class="text-sm text-[var(--text-dim)]">
                標準エラーコード（13 種）付き V2 プロトコルマニフェストを解析・読み込み。
                ハードコードなしのプロバイダー非依存設定。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">レジリエンスパターン</h3>
              <p class="text-sm text-[var(--text-dim)]">
                組み込みの RetryPolicy、CircuitBreaker、RateLimiter、Backpressure。
                PreflightChecker による統一リクエストゲート。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">モデルルーティング</h3>
              <p class="text-sm text-[var(--text-dim)]">
                ModelManager と CostBasedSelector / QualityBasedSelector / FallbackChain。
                コストと品質を最適化するスマート選択。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">マルチモーダル対応</h3>
              <p class="text-sm text-[var(--text-dim)]">
                音声認識の SttClient、音声合成の TtsClient、再ランキングの RerankerClient。
                マルチモーダルコンテンツブロックを完全サポート。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">MCP ツールブリッジ</h3>
              <p class="text-sm text-[var(--text-dim)]">
                MCP ツールを AI-Protocol 形式へ橋渡し。統一ツール呼び出しで MCP サーバーを統合。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">バッチとプラグイン</h3>
              <p class="text-sm text-[var(--text-dim)]">
                並行度設定可能な BatchExecutor。リクエスト / レスポンス傍受用フック付きプラグイン。
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Code Example -->
      <section class="section">
        <div class="container">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
            <div>
              <h2 class="text-3xl font-bold text-[var(--text)] mb-4">シンプルで統一された API</h2>
              <p class="text-[var(--text-dim)] mb-6 leading-relaxed">
                同じコードが 37+ プロバイダーで動作します。モデル識別子を変えるだけ —the
                protocol manifest handles everything else.
              </p>
              <ul class="space-y-3">
                <li class="flex items-center gap-3">
                  <span
                    class="w-8 h-8 rounded-full bg-blue-500/10 text-blue-400 flex items-center justify-center text-sm font-bold"
                    >1</span
                  >
                  <span class="text-[var(--text-dim)]">モデル ID でクライアントを作成</span>
                </li>
                <li class="flex items-center gap-3">
                  <span
                    class="w-8 h-8 rounded-full bg-blue-500/10 text-blue-400 flex items-center justify-center text-sm font-bold"
                    >2</span
                  >
                  <span class="text-[var(--text-dim)]">流暢な API でチャットリクエストを構築</span>
                </li>
                <li class="flex items-center gap-3">
                  <span
                    class="w-8 h-8 rounded-full bg-blue-500/10 text-blue-400 flex items-center justify-center text-sm font-bold"
                    >3</span
                  >
                  <span class="text-[var(--text-dim)]">実行またはストリームで応答を取得</span>
                </li>
              </ul>
            </div>
            <div class="bg-[#0d1117] border border-[var(--border)] rounded-lg overflow-hidden">
              <div
                class="bg-[var(--bg-alt)] px-4 py-2 border-b border-[var(--border)] flex items-center gap-2"
              >
                <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
                <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
                <span class="ml-4 text-xs text-[var(--text-muted)] font-mono">chat.ts</span>
              </div>
              <pre
                class="p-4 text-sm overflow-x-auto"><code class="text-[var(--text-dim)]"><span class="text-purple-400">import</span> {'{'} AiClient, Message {'}'} <span class="text-purple-400">from</span> <span class="text-green-300">'@ailib-official/ai-lib-ts'</span>;

<span class="text-purple-400">const</span> client = <span class="text-purple-400">await</span> AiClient.<span class="text-blue-300">new</span>(<span class="text-green-300">'openai/gpt-4o'</span>);

<span class="text-purple-400">const</span> response = <span class="text-purple-400">await</span> client
  .<span class="text-blue-300">chat</span>([
    Message.<span class="text-blue-300">system</span>(<span class="text-green-300">'You are helpful.'</span>),
    Message.<span class="text-blue-300">user</span>(<span class="text-green-300">'Hello!'</span>),
  ])
  .<span class="text-blue-300">temperature</span>(<span class="text-orange-300">0.7</span>)
  .<span class="text-blue-300">execute</span>();

console.<span class="text-blue-300">log</span>(response.content);</code></pre>
            </div>
          </div>
        </div>
      </section>

      <!-- Architecture -->
      <section class="section-alt">
        <div class="container">
          <div class="text-center mb-10">
            <h2 class="text-3xl font-bold text-[var(--text)] mb-4">内部アーキテクチャ</h2>
            <p class="text-lg text-[var(--text-dim)] max-w-2xl mx-auto">
              プロトコル駆動アーキテクチャ：型安全な実行、既定のレジリエンス、完全な拡張性。
            </p>
          </div>
          <RuntimeArch locale={locale} variant="ts" />
        </div>
      </section>

      <!-- Module Overview -->
      <section class="section">
        <div class="container">
          <h2 class="text-3xl font-bold text-[var(--text)] mb-10 text-center">モジュール概要</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">client/ + errors/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                AiClient、ChatRequestBuilder、ChatResponse、CallStats、CancelToken、
                CancellableStream、統一エラーコード。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">protocol/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                ProtocolLoader（ローカル / fetch / GitHub）、V2 マニフェスト、JSON Schema 検証、
                プロバイダー非依存モデル。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">pipeline/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                Decoder（SSE、JSON Lines）、Selector（JSONPath）、Accumulator、FanOut、EventMapper
                （プロトコル駆動）。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">resilience/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                RetryPolicy、CircuitBreaker、RateLimiter、Backpressure、PreflightChecker、
                SignalsSnapshot、FallbackChain。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">routing/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                ModelManager、QualityBasedSelector、CostBasedSelector、FallbackChain による知的選択。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">mcp/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                McpBridge と McpTool 定義で Model Context Protocol サーバーを統合。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">multimodal/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                SttClient、TtsClient、RerankerClient。マルチモーダル入力と専用モデルを完全サポート。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-blue-400 mb-1 font-mono">plugins/ + batch/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                PluginRegistry、Hooks。並行上限付き BatchExecutor。
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Documentation Links -->
      <section class="section-alt">
        <div class="container">
          <h2 class="text-3xl font-bold text-[var(--text)] mb-10 text-center">ドキュメント</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <a
              href="/ja/ts/quickstart/"
              class="block p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-blue-500/40 transition-all hover:no-underline"
            >
              <h3 class="font-bold text-[var(--text)] mb-2">クイックスタート →</h3>
              <p class="text-sm text-[var(--text-dim)]">数分で始められます。</p>
            </a>
            <a
              href="/ja/ts/client/"
              class="block p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-blue-500/40 transition-all hover:no-underline"
            >
              <h3 class="font-bold text-[var(--text)] mb-2">AiClient API →</h3>
              <p class="text-sm text-[var(--text-dim)]">完全な API リファレンス。</p>
            </a>
            <a
              href="/ja/ts/streaming/"
              class="block p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-blue-500/40 transition-all hover:no-underline"
            >
              <h3 class="font-bold text-[var(--text)] mb-2">ストリーミング →</h3>
              <p class="text-sm text-[var(--text-dim)]">リアルタイム応答処理。</p>
            </a>
            <a
              href="/ja/ts/resilience/"
              class="block p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-blue-500/40 transition-all hover:no-underline"
            >
              <h3 class="font-bold text-[var(--text)] mb-2">レジリエンス →</h3>
              <p class="text-sm text-[var(--text-dim)]">本番向けパターン。</p>
            </a>
            <a
              href="/ja/ts/advanced/"
              class="block p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-blue-500/40 transition-all hover:no-underline"
            >
              <h3 class="font-bold text-[var(--text)] mb-2">高度な機能 →</h3>
              <p class="text-sm text-[var(--text-dim)]">埋め込み、MCP、プラグイン。</p>
            </a>
            <a
              href="/ja/ts/overview/"
              class="block p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-blue-500/40 transition-all hover:no-underline"
            >
              <h3 class="font-bold text-[var(--text)] mb-2">概要 →</h3>
              <p class="text-sm text-[var(--text-dim)]">アーキテクチャと概念。</p>
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer locale={locale} />
  </body>
</html>

<style>
  .gradient-text {
    background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
