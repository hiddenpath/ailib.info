      </section>

      <!-- Runtime Comparison Table -->
      <section class="section-alt">
        <div class="container">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-4">Elige tu runtime</h2>
            <p class="text-lg text-[var(--text-dim)] max-w-2xl mx-auto">
              Mismo protocolo, diferentes fortalezas. Elige el runtime que encaje con tu stack.
            </p>
          </div>

          <div class="overflow-x-auto rounded-xl border border-[var(--border)]">
            <table class="w-full text-left border-collapse">
