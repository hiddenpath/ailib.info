                  <th
                    class="p-4 text-sm font-semibold text-cyan-400 border-b border-[var(--border)]"
                    >Go SDK</th
                  >
                </tr>
              </thead>
              <tbody class="text-sm">
                <tr class="border-b border-[var(--border)]">
                  <td class="p-4 font-medium text-[var(--text)]">Sistema de tipos</td>
                  <td class="p-4 text-[var(--text-dim)]">JSON Schema</td>
                  <td class="p-4 text-[var(--text-dim)]">Tiempo de compilaciĂłn (Rust)</td>
                  <td class="p-4 text-[var(--text-dim)]">Tiempo de ejecuciĂłn (Pydantic v2)</td>
                  <td class="p-4 text-[var(--text-dim)]">Tiempo de compilaciĂłn (TypeScript)</td>
