---
import '../../styles/global.css';
import SiteHeader from '../../components/SiteHeader.astro';
import Hero from '../../components/Hero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Providers from '../../components/Providers.astro';
import EcosystemOverview from '../../components/diagrams/EcosystemOverview.astro';
import DataFlow from '../../components/diagrams/DataFlow.astro';
import Footer from '../../components/Footer.astro';

const locale = 'es';
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <title>AI-Lib | Un protocolo, todos los proveedores de IA</title>
    <meta
      name="description"
      content="AI-Lib es un ecosistema de cĂłdigo abierto que estandariza las interacciones con modelos de IA. Cuatro runtimes (Rust, Python, TypeScript, Go) con MCP, STT/TTS/Rerank y multimodal â€?37+ proveedores."
    />
    <meta name="keywords" content="AI, LLM, OpenAI, Anthropic, Gemini, Claude, GPT, aprendizaje automĂˇtico, inteligencia artificial, SDK, Rust, Python, TypeScript, Go, MCP, multimodal" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta property="og:title" content="AI-Lib | Un protocolo, todos los proveedores de IA" />
    <meta
      property="og:description"
      content="Ecosistema de cĂłdigo abierto para interacciones con modelos de IA estandarizadas. Un protocolo, mĂşltiples runtimes."
    />
    <meta property="og:image" content="/og-image-es.png" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <SiteHeader locale={locale} />

    <main>
      <Hero locale={locale} />

      <!-- Core Projects -->
      <section class="section-alt">
        <div class="container">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-4">
              6 proyectos, 1 ecosistema
            </h2>
            <p class="text-lg text-[var(--text-dim)] max-w-2xl mx-auto">
              Una capa de especificaciĂłn define las reglas. Cuatro implementaciones de runtime
              (Rust, Python, TypeScript, Go) las hacen realidad.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <ProjectCard
              locale={locale}
              variant="protocol"
              version="1.0.0"
              title="AI-Protocol"
              description="EspecificaciĂłn V2 con manifiestos de tres anillos, MCP, Computer Use y multimodal â€?sin lĂłgica hardcodeada."
              features={[
                '37+ manifiestos (10 V2 + 27 V1)',
                'Arquitectura de pirĂˇmide de tres anillos V2',
                'STT/TTS/Rerank en manifiestos (Jina, OpenAI, Cohere)',
                'Schemas MCP / CU / Multimodal',
                'ProviderContract + schema de precios',
                'Herramienta CLI de validaciĂłn',
                'ValidaciĂłn de JSON Schema',
                'ConfiguraciĂłn recargable en caliente',
              ]}
              link="/es/protocol/"
              github="https://github.com/ailib-official/ai-protocol"
            />
            <ProjectCard
              locale={locale}
              variant="rust"
              version="1.0.0"
              title="ai-lib-rust"
              description="Runtime Rust de alto rendimiento. CĂłdigos de error estĂˇndar V2, flags de caracterĂ­sticas, pipeline de streaming basado en operadores, seguridad en tiempo de compilaciĂłn y sobrecarga submilisegundo."
              features={[
                'ProviderDriver (OpenAI/Anthropic/Gemini)',
                'MCP tool bridge + aislamiento de namespace',
                'Computer Use + SafetyPolicy',
                'ValidaciĂłn multimodal extendida',
                'Embeddings y cachĂ©',
                'Sistema de plugins',
                '185+ tests, publicado en Crates.io',
              ]}
              link="/es/rust/"
              github="https://github.com/ailib-official/ai-lib-rust"
            />
            <ProjectCard
              locale={locale}
              variant="python"
              version="1.0.0"
              title="ai-lib-python"
              description="Runtime Python amigable para desarrolladores. CĂłdigos de error estĂˇndar V2, extras por capacidad, soporte async completo, tipos Pydantic v2 y telemetrĂ­a de producciĂłn."
              features={[
                'ProviderDriver (OpenAI/Anthropic/Gemini)',
                'MCP tool bridge + aislamiento de namespace',
                'Computer Use + SafetyPolicy',
                'Extras STT/TTS/Rerank',
                'Seguridad de tipos Pydantic v2',
                'Enrutamiento y balanceo de carga de modelos',
                '75+ tests V2, publicado en PyPI',
              ]}
              link="/es/python/"
              github="https://github.com/ailib-official/ai-lib-python"
            />
            <ProjectCard
              locale={locale}
              variant="ts"
              version="1.0.0"
              title="ai-lib-ts"
              description="Runtime TypeScript/Node.js para el ecosistema npm. Impulsado por protocolo, streaming-first, con Resilience, Routing, MCP y soporte multimodal."
              features={[
                'Parsing de manifiestos V2 + cĂłdigos de error estĂˇndar',
                'Resilience (Retry, CircuitBreaker, RateLimiter, Backpressure)',
                'ModelManager + CostBasedSelector + FallbackChain',
                'SttClient, TtsClient, RerankerClient',
                'McpToolBridge, EmbeddingClient, Plugins',
                'BatchExecutor + PreflightChecker',
                'fetch nativo, publicado en npm',
              ]}
