              github="https://github.com/ailib-official/ai-lib-ts"
            />
            <ProjectCard
              locale={locale}
              variant="go"
              version="1.0.0"
              title="ai-lib-go"
              description="Runtime Go de alta concurrencia optimizado para despliegues en servidor. Asigna la especificaciĂłn V2 a iteraciĂłn de flujos estĂˇndar de manera impecable."
              features={[
                'Arquitectura ProviderDriver',
                'Concurrencia nativa de Go 1.21+',
                'Resiliencia sensible al contexto',
                'Mapeo estricto de JSON Schema a Structs',
                'Transporte nativo net/http',
              ]}
              link="/es/go/"
              github="https://github.com/ailib-official/ai-lib-go"
            />
          </div>
          <div class="mt-12 pt-8 border-t border-[var(--border)]">
            <h3 class="text-lg font-semibold text-[var(--text)] mb-4">
              Herramientas de desarrollo
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
