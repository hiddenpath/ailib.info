                  <td class="p-4 text-[var(--text-dim)]">EspecificaciĂłn SSE/NDJSON</td>
                  <td class="p-4 text-[var(--text-dim)]">tokio async streams</td>
                  <td class="p-4 text-[var(--text-dim)]">async generators</td>
