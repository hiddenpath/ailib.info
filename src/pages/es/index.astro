                  <td class="p-4 text-[var(--text-dim)]">McpToolBridge</td>
                  <td class="p-4 text-[var(--text-dim)]">McpToolBridge</td>
                  <td class="p-4 text-[var(--text-dim)]">McpToolBridge</td>
                  <td class="p-4 text-[var(--text-dim)]">Planeado</td>
                </tr>
                <tr class="border-b border-[var(--border)]">
                  <td class="p-4 font-medium text-[var(--text)]">Computer Use</td>
                  <td class="p-4 text-[var(--text-dim)]">Esquema computer-use.json</td>
                  <td class="p-4 text-[var(--text-dim)]">ComputerAction + SafetyPolicy</td>
                  <td class="p-4 text-[var(--text-dim)]">ComputerAction + SafetyPolicy</td>
                  <td class="p-4 text-[var(--text-dim)]">â€?/td>
                  <td class="p-4 text-[var(--text-dim)]">â€?/td>
                </tr>
                <tr class="border-b border-[var(--border)]">
                  <td class="p-4 font-medium text-[var(--text)]">Multimodal</td>
                  <td class="p-4 text-[var(--text-dim)]">Esquema multimodal.json</td>
                  <td class="p-4 text-[var(--text-dim)]">MultimodalCapabilities</td>
