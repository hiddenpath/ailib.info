                github="https://github.com/ailib-official/zerospider"
              />
              <ProjectCard
                locale={locale}
                variant="showcase"
                version="0.3.0"
                title="SpiderSwitch"
                description="Servidor MCP para cambio dinĂˇmico de modelos AI. Permite a los agentes descubrir, cambiar y gestionar modelos AI entre proveedores mediante herramientas MCP estĂˇndar."
