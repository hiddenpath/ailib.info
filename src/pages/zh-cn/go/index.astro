---
import '../../../styles/global.css';
import SiteHeader from '../../../components/SiteHeader.astro';
import Footer from '../../../components/Footer.astro';
import RuntimeArch from '../../../components/diagrams/RuntimeArch.astro';

const locale = 'zh-cn';
---

<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <title>ai-lib-go | AI-Protocol Go 运行时</title>
    <meta
      name="description"
      content="ai-lib-go 是 AI-Protocol 的 Go 运行时。pkg/ailib 执行层 + pkg/contact 回退策略，协议优先 HTTP 与 ExecutionMetadata。"
    />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <SiteHeader locale={locale} />

    <main>
      <!-- Hero -->
      <section class="relative pt-16 pb-20 overflow-hidden">
        <div class="absolute inset-0 -z-10">
          <div class="absolute top-0 right-1/4 w-96 h-96 bg-orange-500/5 rounded-full blur-3xl">
          </div>
          <div class="absolute bottom-0 left-1/3 w-80 h-80 bg-red-500/5 rounded-full blur-3xl">
          </div>
        </div>
        <div class="container">
          <div class="max-w-4xl">
            <div
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-orange-500/10 text-orange-400 border border-orange-500/20 mb-6"
            >
              v1.0.0 &middot; Pkg.go.dev
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6 leading-[1.05]">
              <span class="gradient-text-rust">Go 运行时</span>
              <br />
              <span class="text-[var(--text)]">适用于 AI-Protocol。</span>
            </h1>
            <p class="text-lg md:text-xl text-[var(--text-dim)] max-w-2xl mb-8 leading-relaxed">
              Go 协议运行时（v1.0.0）。pkg/ailib 负责清单 HTTP 聊天；pkg/contact 提供回退策略。
              13 个 V2 错误码、ChatStream SSE 解码器，响应附带 ExecutionMetadata。Go 1.21+。
            </p>
            <div class="flex flex-wrap gap-4 mb-8">
              <a
                href="/zh-cn/rust/quickstart/"
                class="inline-flex items-center gap-2 px-6 py-3 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition-all hover:no-underline"
                >快速开始</a
              >
              <a
                href="https://github.com/ailib-official/ai-lib-go"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] text-[var(--text)] font-semibold rounded-lg hover:bg-[var(--bg-alt)] transition-all hover:no-underline"
                >GitHub</a
              >
              <a
                href="https://pkg.go.dev/github.com/ailib-official/ai-lib-go"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] text-[var(--text)] font-semibold rounded-lg hover:bg-[var(--bg-alt)] transition-all hover:no-underline"
                >Pkg.go.dev</a
              >
            </div>

            <!-- Quick install -->
            <div class="bg-[#0d1117] border border-[var(--border)] rounded-lg p-4 max-w-lg">
              <div class="text-xs text-[var(--text-muted)] mb-2 font-mono">go get</div>
              <code class="text-sm text-orange-300 font-mono"
                >go get github.com/ailib-official/ai-lib-go@v1.0.0</code
              >
            </div>
          </div>
        </div>
      </section>

      <!-- Key Features -->
      <section class="section-alt">
        <div class="container">
          <h2 class="text-3xl font-bold text-[var(--text)] mb-10 text-center">核心特性</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">V2 错误码与 Feature 开关</h3>
              <p class="text-sm text-[var(--text-dim)]">
                13 个 V2 标准错误码，跨服务商统一错误处理。
                Feature 门控模块：7 个可选能力，外加 full 元特性，可按需精简或完整构建。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">算子流式管道</h3>
              <p class="text-sm text-[var(--text-dim)]">
                流式响应经可组合算子处理：Decoder &rarr; Selector
                &rarr; Accumulator &rarr; FanOut &rarr; EventMapper。各阶段均由协议配置驱动。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">协议加载</h3>
              <p class="text-sm text-[var(--text-dim)]">
                从本地文件、环境变量或 GitHub 回退加载服务商清单。
                支持文件监视热重载，配置更新无需重启。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">韧性模式</h3>
              <p class="text-sm text-[var(--text-dim)]">
                内置熔断、令牌桶限流、指数退避重试与 max-inflight 背压。
                均可通过环境变量配置。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">嵌入与向量</h3>
              <p class="text-sm text-[var(--text-dim)]">
                EmbeddingClient 提供向量运算 ??cosine similarity, Euclidean distance, dot
                product. 可原生构建语义检索与 RAG 应用。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">缓存与批处理</h3>
              <p class="text-sm text-[var(--text-dim)]">
                带 TTL 的响应缓存（内存后端）。批处理支持可配置并发、超时与多种执行策略。
              </p>
            </div>
            <div class="p-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="font-bold text-[var(--text)] mb-2">插件系统</h3>
              <p class="text-sm text-[var(--text-dim)]">
                可扩展插件架构，含钩子与中间件链。无需改动核心即可注入自定义行为。
                Guardrails 支持内容过滤与 PII 检测。
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Code Example -->
      <section class="section">
        <div class="container">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
            <div>
              <h2 class="text-3xl font-bold text-[var(--text)] mb-4">统一、简洁的 API</h2>
              <p class="text-[var(--text-dim)] mb-6 leading-relaxed">
                同一套代码适用于全部 37+ 服务商。只需更换模型标识符 ??协议清单会处理其余一切：端点、鉴权、参数映射与流式格式。
              </p>
              <p class="text-[var(--text-dim)] mb-6 leading-relaxed">
                Builder 模式提供流畅的请求构造 API。流式结果统一为 <code>StreamingEvent</code>，
                与底层服务商无关。
              </p>
            </div>
            <div>
              <pre
                class="text-sm !bg-[#0d1117] !border-orange-500/20"><code class="language-go"><span style="color:#ff7b72">use</span> ai_lib_rust::{'{'}AiClient, Message, StreamingEvent{'}'};

<span style="color:#8b949e">// Works with ANY provider ??protocol-driven</span>
<span style="color:#ff7b72">let</span> client = AiClient::new(
    <span style="color:#a5d6ff">"anthropic/claude-3-5-sonnet"</span>
).<span style="color:#ff7b72">await</span>?;

<span style="color:#8b949e">// Builder pattern for chat requests</span>
<span style="color:#ff7b72">let</span> <span style="color:#ff7b72">mut</span> stream = client.chat()
    .user(<span style="color:#a5d6ff">"Explain AI-Protocol"</span>)
    .temperature(<span style="color:#79c0ff">0.7</span>)
    .max_tokens(<span style="color:#79c0ff">1000</span>)
    .stream()
    .execute_stream()
    .<span style="color:#ff7b72">await</span>?;

<span style="color:#8b949e">// Unified streaming events</span>
<span style="color:#ff7b72">while let</span> Some(event) = stream.next().<span style="color:#ff7b72">await</span> {'{'}
    <span style="color:#ff7b72">match</span> event? {'{'}
        StreamingEvent::ContentDelta {'{'} text, .. {'}'}
            => print!(<span style="color:#a5d6ff">"{'{'}text{'}'}"</span>),
        StreamingEvent::StreamEnd {'{'} stats, .. {'}'}
            => println!(<span style="color:#a5d6ff">"\nTokens: {'{'}{'}'}"</span>,
                stats.total_tokens),
        _ => {'{'}{'}'} <span style="color:#8b949e">// ToolCall, Metadata, etc.</span>
    {'}'}
{'}'}</code></pre>
            </div>
          </div>
        </div>
      </section>

      <!-- Architecture -->
      <section class="section-alt">
        <div class="container">
          <div class="text-center mb-10">
            <h2 class="text-3xl font-bold text-[var(--text)] mb-4">内部架构</h2>
            <p class="text-lg text-[var(--text-dim)] max-w-2xl mx-auto">
              从面向用户的 API 到 HTTP 传输共五层。流式管道是系统核心。
            </p>
          </div>
          <RuntimeArch locale={locale} variant="go" />
        </div>
      </section>

      <!-- Module Overview -->
      <section class="section">
        <div class="container">
          <h2 class="text-3xl font-bold text-[var(--text)] mb-10 text-center">模块概览</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">
                client/ + error_code/
              </h3>
              <p class="text-sm text-[var(--text-dim)]">
                AiClient、AiClientBuilder、ChatRequestBuilder、执行逻辑、策略引擎、
                预检、错误分类、CallStats、CancelHandle。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">protocol/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                ProtocolLoader（本地 / URL / GitHub）、JSON Schema 校验、ProtocolManifest
                结构、UnifiedRequest 编译与配置类型。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">pipeline/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                Decoder（SSE、JSON Lines）、Selector（JSONPath）、Accumulator（工具调用）、FanOut
                （多候选）、EventMapper（统一事件），以及 Retry / Fallback 算子。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">transport/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                HttpTransport（reqwest）、API Key 解析（keyring + 环境变量）、代理 / 超时配置与中间件。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">resilience/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                熔断器（open / half-open / closed）、令牌桶限流、max-inflight 信号量背压。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">embeddings/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                EmbeddingClient、EmbeddingClientBuilder，以及向量运算（余弦相似度、欧氏距离、点积）。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">cache/ + batch/</h3>
              <p class="text-sm text-[var(--text-dim)]">
                带 TTL 的 CacheManager（MemoryCache、NullCache）。BatchCollector / BatchExecutor
                支持并发控制与多种策略。
              </p>
            </div>
            <div class="p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
              <h3 class="text-base font-bold text-orange-400 mb-1 font-mono">
                plugins/ + guardrails/ + structured/
              </h3>
              <p class="text-sm text-[var(--text-dim)]">
                Plugin trait、PluginRegistry、HookManager 与中间件链。Guardrails 提供关键词 / 模式过滤与 PII 检测。
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="section-alt">
        <div class="container text-center">
          <h2 class="text-3xl font-bold text-[var(--text)] mb-4">开始使用 Go 构建</h2>
          <div class="flex flex-wrap gap-4 justify-center">
            <a
              href="/zh-cn/go/quickstart/"
              class="inline-flex items-center gap-2 px-6 py-3 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition-all hover:no-underline"
              >快速开始</a
            >
            <a
              href="/zh-cn/go/overview/"
              class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] text-[var(--text)] font-semibold rounded-lg hover:bg-[var(--bg-alt)] transition-all hover:no-underline"
              >完整文档</a
            >
          </div>
        </div>
      </section>
    </main>

    <Footer locale={locale} />
  </body>
</html>
