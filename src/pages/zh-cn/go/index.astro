import SiteHeader from '../../../components/SiteHeader.astro';
import Footer from '../../../components/Footer.astro';
import RuntimeArch from '../../../components/diagrams/RuntimeArch.astro';

const locale = 'zh-cn';
---

<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <title>ai-lib-go | AI-Protocol й«ҳжҖ§иғҪ Rust иҝҗиЎҢж—?/title>
    <meta
      name="description"
      content="ai-lib-go жҳ?AI-Protocol зҡ„й«ҳжҖ§иғҪ Rust иҝҗиЎҢж—¶гҖӮеҹәдәҺз®—еӯҗзҡ„жөҒејҸз®ЎйҒ“гҖҒзј–иҜ‘ж—¶е®үе…ЁгҖҒдәҡжҜ«з§’зә§ејҖй”ҖгҖ?
    />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
